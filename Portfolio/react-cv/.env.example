# Copy this file to .env and fill in your values (do not commit .env)

# Public site URL (no trailing slash) — used for canonical URLs, Open Graph, JSON-LD. Set on Vercel to your live domain, e.g. https://your-site.vercel.app
# VITE_SITE_URL=https://your-site.vercel.app

# Optional: full URL to a 1200×630 PNG/JPG for social previews (overrides default placeholder).
# VITE_OG_IMAGE=https://your-site.vercel.app/og-image.png

# Optional: Google Search Console verification meta (content token only).
# VITE_GOOGLE_SITE_VERIFICATION=

# Supabase (required for Portfolio, Blog, Resume, Admin)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gmail (set these in Vercel Dashboard → Settings → Environment Variables, not here)
# GMAIL_USER=your@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
